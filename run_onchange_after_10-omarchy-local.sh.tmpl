{{- if eq .chezmoi.os "linux" -}}
#!/usr/bin/env bash
set -euo pipefail

if ! command -v omarchy >/dev/null 2>&1; then
    exit 0
fi

section() {
    printf '\n\033[1;34m==> %s\033[0m\n' "$1"
}

success() {
    printf '\033[1;32m%s\033[0m\n' "$1"
}

install_core_packages() {
    section "Installing Omarchy packages"

    omarchy pkg add \
        chezmoi \
        eza \
        fd \
        ffmpeg \
        fzf \
        github-cli \
        micro \
        mosh \
        npm \
        obsidian \
        starship \
        tailscale \
        tmux \
        zoxide \
        bitwarden \
        localsend \
        claude-code \
        discord
}

install_omp() {
    section "Installing Oh My Pi"

    if command -v omp >/dev/null 2>&1; then
        return
    fi

    npm install --global --prefix "$HOME/.local" @oh-my-pi/pi-coding-agent
}

install_desktop_preferences() {
    section "Installing preferred desktop apps"

    omarchy install terminal ghostty
    omarchy pkg add zed omazed

    if command -v omazed >/dev/null 2>&1; then
        omazed setup
    fi

    if pacman -Q zen-browser-bin >/dev/null 2>&1 || omarchy install browser zen; then
        omarchy default browser zen
    else
        echo "Zen Browser failed to install; leaving the default browser unchanged." >&2
    fi
}

apply_defaults() {
    section "Applying Omarchy defaults"

    omarchy default terminal ghostty
    omarchy default editor zed
    omarchy theme set "Tokyo Night"
}

patch_hypr_bindings() {
    section "Patching Hyprland app bindings"

    python3 <<'PY'
from pathlib import Path

path = Path.home() / ".config" / "hypr" / "bindings.conf"
if not path.exists():
    raise SystemExit(0)

lines = path.read_text().splitlines()

desired = [
    'bindd = SUPER SHIFT, N, Zed, exec, omarchy-launch-or-focus zed "uwsm-app -- zeditor"',
    'bindd = SUPER SHIFT, D, Discord, exec, omarchy-launch-or-focus discord "uwsm-app -- discord"',
    'bindd = SUPER SHIFT, O, Obsidian, exec, omarchy-launch-or-focus ^obsidian$ "uwsm-app -- obsidian"',
    'bindd = SUPER SHIFT, SLASH, Bitwarden, exec, omarchy-launch-or-focus bitwarden "uwsm-app -- bitwarden"',
]

# Replace only the preinstalled-app bindings that conflict with this setup.
# Leave web apps and core Omarchy navigation/media bindings intact.
remove_prefixes = (
    "bindd = SUPER SHIFT, M,",
    "bindd = SUPER SHIFT ALT, M,",
    "bindd = SUPER SHIFT, N,",
    "bindd = SUPER SHIFT, D,",
    "bindd = SUPER SHIFT, G,",
    "bindd = SUPER SHIFT, O,",
    "bindd = SUPER SHIFT, W,",
    "bindd = SUPER SHIFT, SLASH,",
)

out = []
inserted = False
for line in lines:
    if line.startswith(remove_prefixes):
        continue

    out.append(line)

    if line.startswith("bindd = SUPER SHIFT ALT, B,"):
        out.extend(desired)
        inserted = True

if not inserted:
    for index, line in enumerate(out):
        if line.strip() == "# Application bindings":
            out[index + 1:index + 1] = desired
            inserted = True
            break

if not inserted:
    out = desired + [""] + out

new_text = "\n".join(out).rstrip() + "\n"
old_text = path.read_text()
if new_text != old_text:
    path.write_text(new_text)
    print(f"Updated {path}")
else:
    print(f"{path} already up to date")
PY
}

remove_redundant_preinstalls() {
    section "Removing redundant Omarchy preinstalls"

    # Do not use `omarchy remove preinstalls`: it removes Obsidian/Claude Code
    # and resets bindings more broadly than this dotfiles setup wants.
    # Keep Chromium because Omarchy web apps use its wrapper.
    omarchy pkg drop \
        aether \
        cliamp \
        typora \
        spotify \
        libreoffice-fresh \
        1password-beta \
        1password-cli \
        xournalpp \
        signal-desktop \
        pinta \
        obs-studio \
        kdenlive \
        lazydocker \
        opencode
}

validate_hyprland() {
    if command -v hyprctl >/dev/null 2>&1 && hyprctl instances >/dev/null 2>&1; then
        section "Validating Hyprland config"
        hyprctl reload
        hyprctl configerrors
    fi
}

install_core_packages
install_omp
install_desktop_preferences
apply_defaults
patch_hypr_bindings
remove_redundant_preinstalls
validate_hyprland

success "Omarchy local setup complete."
{{- else -}}
#!/usr/bin/env bash
exit 0
{{- end }}
